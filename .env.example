# ---------------------------------------------------------------------------
# Sports-Hub configuration
# Copy this file to ".env" and fill in your values, then run `npm start`.
# ---------------------------------------------------------------------------

# Your API-Sports key. ONE key works across all API-Sports sports.
# Get it from https://dashboard.api-sports.io (free plan = ~100 requests/day per sport).
# Leave blank to run the app in DEMO mode with bundled sample data.
API_SPORTS_KEY=

# Port the web app runs on
PORT=3000

# ---------------------------------------------------------------------------
# Seasons (API-Sports requires a season for standings/schedule queries).
# A "season" is the starting year, e.g. the 2025-26 NFL season is 2025.
# ---------------------------------------------------------------------------
NFL_SEASON=2025
NBA_SEASON=2025
MLB_SEASON=2026
SOCCER_SEASON=2025

# ---------------------------------------------------------------------------
# Soccer league to follow (API-Football league IDs).
# 39 = English Premier League, 140 = La Liga, 2 = UEFA Champions League,
# 1 = FIFA World Cup. Change to whatever you're into.
# ---------------------------------------------------------------------------
SOCCER_LEAGUE=39

# Cache time-to-live in seconds. Higher = fewer API calls (kinder to the free tier).
# Live scores use a shorter window automatically.
CACHE_TTL_SECONDS=900
