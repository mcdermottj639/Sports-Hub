# Copy these into your host's "Variables" / "Secrets" panel (NOT committed).
# Cookies are only needed for PRIVATE leagues. Public leagues can skip them.

# --- ESPN login cookies (shared across all your leagues) ---
ESPN_S2=
SWID=

# --- which leagues to pull (the leagueId=XX…  in your ESPN URL) ---
FOOTBALL_LEAGUE_ID=
FOOTBALL_YEAR=2025
FOOTBALL_TEAM_ID=

BASEBALL_LEAGUE_ID=42353353
BASEBALL_YEAR=2026
BASEBALL_TEAM_ID=2

# --- which frontends may read this API (comma-separated) ---
ALLOW_ORIGINS=https://mcdermottj639.github.io,http://localhost:8000

# --- how long (seconds) a league snapshot is cached before re-pulling from
#     ESPN. Default 300 (5 min). Lower = fresher but more ESPN calls; 0 disables
#     caching entirely. The app's "Refresh from ESPN" button clears it on demand.
LEAGUE_TTL_SECONDS=300
